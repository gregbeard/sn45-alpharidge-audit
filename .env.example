# sn45 audit sidecar configuration
# Copy to .env and edit. Environment variables set outside this file take
# precedence. The three REQUIRED values have no defaults — the exporter exits
# with an error naming any that are missing.

# ---------------------------------------------------------------- REQUIRED --
# Path to your local checkout of the validator repo (Team-Rizzo/alpharidge-ai).
# Read-only: the exporter imports its scoring modules and reads its state files.
ALPHARIDGE_REPO=/home/YOUR_USER/sn45/alpharidge-ai

# Your subtensor ARCHIVE node (must serve historical state at past blocks).
# A non-archive node will fail historical queries. Public fallback:
# wss://archive.chain.opentensor.ai:443 (slower; rate limits may apply).
ARCHIVE_SUBTENSOR_ENDPOINT=ws://YOUR_ARCHIVE_NODE:9944

# YOUR validator's hotkey ss58 — used to find your uid, detect your
# set_weights commits on chain, and capture your on-chain weight vector.
VALIDATOR_HOTKEY_SS58=5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------- exporter --
# pm2 process name of your running validator (the exporter parses
# ~/.pm2/logs/<prefix>-out.log and <prefix>-error.log).
VALIDATOR_LOG_PREFIX=alpharidge.validator
# PM2_LOG_DIR=/home/YOUR_USER/.pm2/logs
# NETUID=45
# POLL_INTERVAL_SECONDS=120
# AUDIT_DATA_DIR=      # default: <this repo>/data/epoch_archives
# Interpreter override for pm2 (default: $ALPHARIDGE_REPO/.venv/bin/python).
# Point at any python that has bittensor+numpy+pydantic+requests installed —
# e.g. a conda env: /home/YOUR_USER/miniconda3/envs/YOUR_ENV/bin/python
# VALIDATOR_VENV_PYTHON=

# ----------------------------------------------------------------- sidecar --
AUDIT_PORT=18889
AUDIT_BIND=0.0.0.0
# AUDIT_ARCHIVE_SOURCE=   # default: <this repo>/data/epoch_archives; may also
#                         # be a public https URL serving the archives + index.json
# AUDIT_RELOAD_INTERVAL_S=60
# AUDIT_PRICE_DRIFT_TOL=0.05   # tolerance for TAO/USD price-cache drift checks
# AUDIT_STALE_AFTER_S=3600     # dashboard shows STALE + /health 503 past this
# SIDECAR_PYTHON=python3       # any python3, stdlib only
